+def _memory_peak_bytes() -> int | None:
+    try:
+        usage = resource.getrusage(resource.RUSAGE_SELF)
+        peak = int(usage.ru_maxrss)
+    except Exception:
+        return None
+    if peak <= 0:
+        return None
+    if sys.platform.startswith("linux"):
+        return peak * 1024
+    return peak
+
