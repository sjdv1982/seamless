+            "sys_path_hash": "s" * 64,
+            "ld_library_path_entries": ["/env/lib"],
+            "ld_preload_entries": [],
+        },
+    )
+    monkeypatch.setattr(
+        probe_capture,
+        "_environment_contract_summary",
