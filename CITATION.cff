    given-names: "Sjoerd"
repository-code: "https://github.com/sjdv1982/seamless"
url: "https://sjdv1982.github.io/seamless/"
keywords:
  - workflow
  - reproducibility
  - caching
  - content-addressed
  - scientific-computing
  - HPC
  - pipeline
